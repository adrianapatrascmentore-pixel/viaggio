<script>
// Particles
const pts=document.getElementById('pts');
for(let i=0;i<60;i++){
  const p=document.createElement('div');p.className='p';
  const s=Math.random()*2+0.4;
  p.style.cssText=`width:${s}px;height:${s}px;top:${Math.random()*100}%;left:${Math.random()*100}%;--d:${2+Math.random()*5}s;animation-delay:${Math.random()*6}s;`;
  pts.appendChild(p);
}

// Scroll reveal
const obs=new IntersectionObserver(entries=>{
  entries.forEach((e,i)=>{
    if(e.isIntersecting){setTimeout(()=>e.target.classList.add('on'),i*70);obs.unobserve(e.target);}
  });
},{threshold:0.08});
document.querySelectorAll('.r').forEach(el=>obs.observe(el));

// FAQ
function tog(btn){
  const item=btn.parentElement;
  const open=item.classList.contains('open');
  document.querySelectorAll('.faq-item.open').forEach(i=>i.classList.remove('open'));
  if(!open)item.classList.add('open');
}

// Countdown
const KEY='viaggio_end_v3';
let end=localStorage.getItem(KEY);
if(!end){end=Date.now()+72*3600*1000;localStorage.setItem(KEY,end);}
end=Number(end);
function fmt(ms){
  const h=Math.floor(ms/3600000),m=Math.floor((ms%3600000)/60000),s=Math.floor((ms%60000)/1000);
  return `${String(h).padStart(2,'0')}:${String(m).padStart(2,'0')}:${String(s).padStart(2,'0')}`;
}
function tick(){
  const diff=Math.max(0,end-Date.now()),str=fmt(diff);
  document.getElementById('timer').textContent=str;
  const t2=document.getElementById('timer2');if(t2)t2.textContent=str;
}
tick();setInterval(tick,1000);
</script>
</body>
</html>
